{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && ($uid === auth.uid || ((root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'admin') && root.child('users').child(auth.uid).child('ws').val() === data.child('ws').val()))"
      }
    },
    "notes": {
      "$nid": {
        ".read": "auth != null && $nid === 'user_' + auth.uid",
        ".write": "auth != null && $nid === 'user_' + auth.uid"
      }
    },
    "workspaces": {
      ".read": "auth != null",
      "$ws": {
        ".write": "auth != null && ((!data.exists() && newData.child('owner').val() === auth.uid) || data.child('owner').val() === auth.uid || ((root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'admin') && root.child('users').child(auth.uid).child('ws').val() === $ws))",
        ".validate": "newData.hasChildren(['name', 'owner'])"
      }
    },
    "ws": {
      "$ws": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('ws').val() === $ws",
        ".write": "auth != null && root.child('users').child(auth.uid).child('ws').val() === $ws",
        "status": {
          "$uid": {
            ".validate": "newData.hasChildren(['state', 'ts']) && newData.child('state').val().matches(/^(focus|work|away|vacation)$/)"
          }
        },
        "requests": {
          "$rid": {
            "kind": { ".validate": "newData.isString() && newData.val().matches(/^(memo|task)$/)" },
            "title": { ".validate": "newData.isString() && newData.val().length <= 200" },
            "html": { ".validate": "newData.isString() && newData.val().length <= 200000" },
            "attachments": {
              "$i": {
                "data": { ".validate": "newData.isString() && newData.val().length <= 1500000" }
              }
            }
          }
        }
      }
    }
  }
}
