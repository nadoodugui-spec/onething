          ".validate": "newData.hasChild('name') && newData.child('name').isString() && newData.child('name').val().length <= 40",
          "name": { ".validate": "newData.isString() && newData.val().length <= 40" },
          "role": { ".validate": "newData.val() === null || newData.val().matches(/^(owner|admin|member)$/)" },
          "$other": { ".validate": false }
        }
      }
    },
