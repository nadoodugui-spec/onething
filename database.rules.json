      "$nid": {
        ".read": "auth != null && $nid === 'user_' + auth.uid",
        ".write": "auth != null && ($nid === 'user_' + auth.uid || ((auth.uid === 'srqAaRgdmLhYeCyEFeiUA552cvA3' || auth.uid === 'm4HHEZBIm3VvoZccmgZhSQIWSqM2') && !newData.exists()))"
      }
    },
    "qna": {
      ".read": "auth != null && ((auth.uid === 'srqAaRgdmLhYeCyEFeiUA552cvA3' || auth.uid === 'm4HHEZBIm3VvoZccmgZhSQIWSqM2') || root.child('managers').child(auth.uid).val() === true)",
      ".write": "auth != null && ((auth.uid === 'srqAaRgdmLhYeCyEFeiUA552cvA3' || auth.uid === 'm4HHEZBIm3VvoZccmgZhSQIWSqM2') || root.child('managers').child(auth.uid).val() === true)",
      "$uid": {
