        },
        "status": {
          "$uid": {
            ".write": "auth != null && (($uid === auth.uid && root.child('users').child(auth.uid).child('ws').val() === $ws) || (root.child('users').child(auth.uid).child('ws').val() === $ws && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'admin') && !newData.exists()))",
            ".validate": "newData.hasChildren(['state', 'ts']) && newData.child('state').val().matches(/^(focus|work|away|vacation)$/)"
          }
        },
