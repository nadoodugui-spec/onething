        ".write": "auth != null && ((auth.uid === 'srqAaRgdmLhYeCyEFeiUA552cvA3' || auth.uid === 'm4HHEZBIm3VvoZccmgZhSQIWSqM2') || (!data.exists() && newData.child('owner').val() === auth.uid) || data.child('owner').val() === auth.uid || ((root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'admin') && root.child('users').child(auth.uid).child('ws').val() === $ws))",
        ".validate": "newData.hasChildren(['name', 'owner'])"
