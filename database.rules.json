{
  "rules": {
    "users": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && ($uid === auth.uid || auth.uid === 'srqAaRgdmLhYeCyEFeiUA552cvA3')",
        "ws": {
          ".write": "auth != null && $uid !== auth.uid && (root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'admin') && (data.val() === root.child('users').child(auth.uid).child('ws').val() || newData.val() === root.child('users').child(auth.uid).child('ws').val())"
        },
        "role": {
          ".write": "auth != null && $uid !== auth.uid && root.child('users').child(auth.uid).child('role').val() === 'owner' && (root.child('users').child($uid).child('ws').val() === root.child('users').child(auth.uid).child('ws').val() || newData.parent().child('ws').val() === root.child('users').child(auth.uid).child('ws').val())"
        }
      }
    },
    "notes": {
      "$nid": {
        ".read": "auth != null && $nid === 'user_' + auth.uid",
        ".write": "auth != null && $nid === 'user_' + auth.uid"
      }
    },
    "managers": {
      ".read": "auth != null",
      "$uid": {
        ".write": "auth != null && auth.uid === 'srqAaRgdmLhYeCyEFeiUA552cvA3'",
        ".validate": "newData.isBoolean()"
      }
    },
    "workspaces": {
      ".read": "auth != null",
      "$ws": {
        ".write": "auth != null && (auth.uid === 'srqAaRgdmLhYeCyEFeiUA552cvA3' || (!data.exists() && newData.child('owner').val() === auth.uid) || data.child('owner').val() === auth.uid || ((root.child('users').child(auth.uid).child('role').val() === 'owner' || root.child('users').child(auth.uid).child('role').val() === 'admin') && root.child('users').child(auth.uid).child('ws').val() === $ws))",
        ".validate": "newData.hasChildren(['name', 'owner'])"
      }
    },
    "ws": {
      "$ws": {
        ".read": "auth != null && (auth.uid === 'srqAaRgdmLhYeCyEFeiUA552cvA3' || root.child('managers').child(auth.uid).val() === true || root.child('users').child(auth.uid).child('ws').val() === $ws)",
        ".write": "auth != null && (auth.uid === 'srqAaRgdmLhYeCyEFeiUA552cvA3' || root.child('users').child(auth.uid).child('ws').val() === $ws)",
        "status": {
          "$uid": {
            ".validate": "newData.hasChildren(['state', 'ts']) && newData.child('state').val().matches(/^(focus|work|away|vacation)$/)"
          }
        },
        "requests": {
          "$rid": {
            "kind": { ".validate": "newData.isString() && newData.val().matches(/^(memo|task)$/)" },
            "title": { ".validate": "newData.isString() && newData.val().length <= 200" },
            "html": { ".validate": "newData.isString() && newData.val().length <= 200000" },
            "attachments": {
              "$i": {
                "data": { ".validate": "newData.isString() && newData.val().length <= 1500000" }
              }
            }
          }
        }
      }
    }
  }
}
